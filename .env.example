# --- Split local targets (recommended for Neon dev branch + production branch) ---
# Put JWT / VAPID / other secrets in `.env.local` (gitignored).
# Put only database URLs in `.env.database.dev` and `.env.database.main` (gitignored).
# Bun loads `.env.local` first, then the database file, so the latter wins for DATABASE_*.
#
#   bun run dev          → Neon dev branch (.env.database.dev)
#   bun run dev:main     → Neon production branch (.env.database.main)
#   bun run db:push      → push schema to dev branch (default)
#   bun run db:push:main → push schema to production (use with care)
#
# Create the two database files from Neon (pooled → DATABASE_URL, direct → DATABASE_URL_DIRECT).

# --- Single-file setup (simplest if you only have one database) ---
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/salon
# DATABASE_URL_DIRECT=postgresql://postgres:postgres@127.0.0.1:5432/salon

# Strong secret in production
JWT_SECRET=change-me-in-production

# Web Push (VAPID). Generate with: bunx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URL (see web-push docs).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
