# PostgreSQL connection used by the app at runtime.
# For Neon on Vercel, use the pooled connection string here.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/salon

# Optional direct Postgres connection for migrations and seeding.
# On Neon, use the non-pooled/direct connection string here.
# On a VPS or another provider, this can be the same as DATABASE_URL.
# DATABASE_URL_DIRECT=postgresql://postgres:postgres@127.0.0.1:5432/salon

# Strong secret in production
JWT_SECRET=change-me-in-production
