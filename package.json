    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3",
    "vitest": "^3.0.5"
  }
