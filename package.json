{
  "name": "aravira-saloon",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.5",
  "scripts": {
    "dev": "bun --env-file=.env.local --env-file=.env.database.dev next dev",
    "dev:multitenant": "bun --env-file=.env.local --env-file=.env.database.multitenant next dev",
    "dev:main": "bun --env-file=.env.local --env-file=.env.database.main next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=.env.local --env-file=.env.database.dev drizzle-kit migrate",
    "db:migrate:multitenant": "bun --env-file=.env.local --env-file=.env.database.multitenant drizzle-kit migrate",
    "db:migrate:main": "bun --env-file=.env.local --env-file=.env.database.main drizzle-kit migrate",
    "db:push": "bun --env-file=.env.local --env-file=.env.database.dev drizzle-kit push",
    "db:push:multitenant": "bun --env-file=.env.local --env-file=.env.database.multitenant drizzle-kit push",
    "db:push:main": "bun --env-file=.env.local --env-file=.env.database.main drizzle-kit push",
    "db:studio": "bun --env-file=.env.local --env-file=.env.database.dev drizzle-kit studio",
    "db:studio:multitenant": "bun --env-file=.env.local --env-file=.env.database.multitenant drizzle-kit studio",
    "db:studio:main": "bun --env-file=.env.local --env-file=.env.database.main drizzle-kit studio",
    "db:seed": "bun --env-file=.env.local --env-file=.env.database.dev scripts/seed.ts",
    "db:seed:multitenant": "bun --env-file=.env.local --env-file=.env.database.multitenant scripts/seed.ts",
    "db:seed:main": "bun --env-file=.env.local --env-file=.env.database.main scripts/seed.ts",
    "test": "bunx vitest run",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:debug": "bunx playwright test --debug",
    "test:e2e:system-chrome": "PLAYWRIGHT_SYSTEM_BROWSER=chrome bunx playwright test"
  },
