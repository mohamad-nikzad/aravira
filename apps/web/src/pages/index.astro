---
export const prerender = true

import Base from '@/layouts/Base.astro'
import { PUBLIC_APP_URL } from '@/env'
import {
  BellRing,
  CalendarDays,
  ChartNoAxesCombined,
  Scissors,
  Sparkles,
  UserPlus,
  UsersRound,
  Wallet,
  type LucideIcon,
} from 'lucide-react'

const title = 'سالورا | مدیریت هوشمند سالن زیبایی'
const description =
  'سالورا نرم‌افزار مدیریت نوبت‌ها، مشتریان، خدمات و پرسنل برای سالن‌های زیبایی است.'
const canonical = new URL('/', Astro.site ?? Astro.url.origin).toString()
const displayClass = 'font-[family-name:var(--font-lalezar)]'

type Feature = {
  title: string
  text: string
  icon: LucideIcon
}

const features: Feature[] = [
  {
    title: 'تقویم نوبت‌ها',
    text: 'برنامه روزانه سالن بر اساس پرسنل و ساعت کاری در یک نگاه.',
    icon: CalendarDays,
  },
  {
    title: 'مدیریت مشتریان',
    text: 'پروفایل، شماره تماس و سابقه مراجعه هر مشتری یک‌جا نگه‌داری می‌شود.',
    icon: UsersRound,
  },
  {
    title: 'مدیریت پرسنل',
    text: 'تخصص، ساعت کاری و نوبت‌های هر همکار به‌صورت جداگانه مدیریت می‌شود.',
    icon: UserPlus,
  },
  {
    title: 'خدمات و دسته‌بندی',
    text: 'برای هر خدمت زمان، قیمت و مجری مشخص کنید تا ثبت نوبت سریع شود.',
    icon: Scissors,
  },
  {
    title: 'گزارش روزانه',
    text: 'درآمد، نوبت‌های انجام‌شده و عملکرد پرسنل را روزانه مشاهده کنید.',
    icon: ChartNoAxesCombined,
  },
  {
    title: 'بازگشت مشتری',
    text: 'مشتریان غیرفعال را شناسایی کنید و آن‌ها را به سالن بازگردانید.',
    icon: BellRing,
  },
]

const stats = [
  { value: '۳ دقیقه', label: 'ثبت یک نوبت کامل' },
  { value: '۱۰۰٪', label: 'فارسی و راست‌چین' },
  { value: '۲۴/۷', label: 'دسترسی از موبایل و دسکتاپ' },
]

const testimonials = [
  {
    name: 'نازنین رحیمی',
    role: 'مدیر سالن نارسیس',
    quote:
      'از وقتی سالورا را راه‌اندازی کردیم، تماس‌های تکراری برای هماهنگی نوبت کم شده و تیم با خیال راحت‌تر کار می‌کند.',
  },
  {
    name: 'سارا یوسفی',
    role: 'متخصص رنگ و لایت',
    quote:
      'برنامه روزانه‌ام را روی موبایل می‌بینم و دیگر نگران تداخل نوبت‌ها نیستم. گزارش‌های ماهانه هم خیلی کمکم کرده.',
  },
  {
    name: 'مهسا کریمی',
    role: 'پذیرش سالن',
    quote:
      'ثبت مشتری جدید فقط چند ثانیه طول می‌کشد و همه اطلاعات لازم در یک صفحه دیده می‌شود.',
  },
]

const dashboardMetrics = [
  { label: 'مشتریان جدید', value: '۲۴', delta: '+۱۵٪', tone: 'rose' as const },
  { label: 'درآمد امروز', value: '۱۸٬۷۵۰٬۰۰۰', delta: '+۸٪', tone: 'amber' as const },
  { label: 'رزروهای امروز', value: '۲۸', delta: '+۱۲٪', tone: 'violet' as const },
  { label: 'خدمات انجام‌شده', value: '۳۴', delta: '+۱۰٪', tone: 'pink' as const },
]

const upcomingAppointments = [
  { time: '۱۰:۰۰', name: 'رنگ و مش', staff: 'نگین محمدی' },
  { time: '۱۱:۳۰', name: 'کراتینه مو', staff: 'سارا یوسفی' },
  { time: '۱۳:۱۵', name: 'کوتاهی مو', staff: 'مینا احمدی' },
  { time: '۱۵:۰۰', name: 'میکاپ', staff: 'الهام کریمی' },
]

const popularServices = [
  { name: 'رنگ و مش', value: 48 },
  { name: 'کراتینه مو', value: 25 },
  { name: 'کوتاهی مو', value: 15 },
  { name: 'میکاپ', value: 12 },
]

const loginHref = new URL('/login', PUBLIC_APP_URL).toString()
const signupHref = new URL('/signup', PUBLIC_APP_URL).toString()

const toneClass: Record<'rose' | 'amber' | 'violet' | 'pink', string> = {
  rose: 'bg-rose-100 text-rose-600',
  amber: 'bg-amber-100 text-amber-600',
  violet: 'bg-violet-100 text-violet-600',
  pink: 'bg-pink-100 text-pink-600',
}
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  preloadLalezar={true}
>
  <main
    dir="rtl"
    class="saloora-landing relative box-border min-h-dvh overflow-hidden bg-[#fdf5f8] text-[#3f2730]"
  >
    <style>
      .saloora-landing {
        max-width: 100%;
        overflow-x: hidden;
      }
      @keyframes saloora-petal {
        0% {
          transform: translate3d(0, -20px, 0) rotate(0deg);
          opacity: 0;
        }
        15% {
          opacity: 0.85;
        }
        100% {
          transform: translate3d(-60px, 540px, 0) rotate(-220deg);
          opacity: 0;
        }
      }
      @media (prefers-reduced-motion: no-preference) {
        .saloora-petal {
          animation: saloora-petal 14s linear infinite;
        }
      }
    </style>

    {/* HERO */}
    <section id="top" class="relative isolate overflow-hidden">
      <img
        src="/landing/hero-bg.webp"
        alt=""
        width="1920"
        height="1080"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 -z-20 hidden h-full w-full object-cover sm:block"
      />
      <img
        src="/landing/hero-bg-mobile.webp"
        alt=""
        width="750"
        height="1334"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 -z-20 h-full w-full object-cover sm:hidden"
      />
      <div
        class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,rgba(253,245,248,0)_0%,rgba(253,245,248,0.45)_70%,#fdf5f8_100%)]"
      >
      </div>

      <span
        class="saloora-petal absolute right-[12%] top-20 h-4 w-2.5 rotate-45 rounded-[8px] bg-rose-300/70"
      ></span>
      <span
        class="saloora-petal absolute right-[42%] top-10 h-3 w-2 rotate-12 rounded-[8px] bg-rose-200/80 [animation-delay:3s]"
      ></span>
      <span
        class="saloora-petal absolute right-[68%] top-28 h-4 w-2.5 -rotate-12 rounded-[8px] bg-pink-300/70 [animation-delay:6s]"
      ></span>
      <span
        class="saloora-petal absolute right-[85%] top-16 h-3 w-2 rotate-45 rounded-[8px] bg-white/80 [animation-delay:9s]"
      ></span>

      <header
        class="relative mx-auto flex w-full max-w-7xl box-border items-center justify-between px-5 py-5 sm:px-8"
      >
        <a href="#top" class="flex items-center gap-2.5" aria-label="سالورا">
          <img
            src="/landing/saloora-mark.png"
            alt=""
            width="44"
            height="44"
            fetchpriority="high"
            decoding="async"
            class="h-10 w-10 sm:h-11 sm:w-11"
          />
          <span class={`${displayClass} text-2xl leading-none text-[#7a2a40] sm:text-3xl`}>
            سالورا
          </span>
        </a>

        <nav class="hidden items-center gap-7 text-sm text-[#6b4955] md:flex">
          <a href="#features" class="transition hover:text-[#7a2a40]"> امکانات </a>
          <a href="#preview" class="transition hover:text-[#7a2a40]"> داشبورد </a>
          <a href="#testimonials" class="transition hover:text-[#7a2a40]"> نظرات </a>
        </nav>

        <a
          href={loginHref}
          class="rounded-md border border-[#d68aa0] bg-white/70 px-4 py-2 text-sm font-bold text-[#7a2a40] backdrop-blur transition hover:bg-[#7a2a40] hover:text-white"
        >
          ورود
        </a>
      </header>

      <div
        class="relative mx-auto flex w-full max-w-4xl box-border flex-col items-center px-5 pb-24 pt-12 text-center sm:px-8 sm:pb-32 sm:pt-20"
      >
        <p
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#e9b4c2] bg-white/70 px-4 py-1.5 text-xs font-bold text-[#7a2a40] backdrop-blur sm:text-sm"
        >
          <Sparkles className="h-4 w-4" aria-hidden="true" />
          مدیریت هوشمند سالن زیبایی
        </p>

        <h1
          class={`${displayClass} text-4xl leading-[1.25] text-[#4a1e2e] sm:text-6xl lg:text-7xl lg:leading-[1.15]`}
        >
          ساده، حرفه‌ای،
          <br />
          <span class="text-[#9b2f4a]">سالورا</span>
        </h1>

        <p class="mt-6 max-w-2xl text-base leading-8 text-[#6b4955] sm:mt-8 sm:text-lg">
          با سالورا تقویم نوبت‌ها، مشتریان، پرسنل و خدمات سالن را در یک مسیر مرتب نگه
          می‌دارید و روز کاری را با تمرکز بیشتری جلو می‌برید.
        </p>

        <div class="mt-9 flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
          <a
            href={signupHref}
            class="rounded-md bg-[#c3425b] px-7 py-3 text-center text-base font-bold text-white shadow-[0_18px_40px_rgba(124,28,48,0.28)] transition hover:bg-[#a82b46]"
          >
            شروع رایگان
          </a>
          <a
            href="#features"
            class="rounded-md border border-[#d68aa0] bg-white/70 px-7 py-3 text-center text-base font-bold text-[#7a2a40] backdrop-blur transition hover:bg-white"
          >
            مشاهده امکانات
          </a>
        </div>
      </div>
    </section>

    {/* FEATURES */}
    <section id="features" class="relative px-5 py-20 sm:px-8 sm:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-sm font-extrabold text-[#9b3348]">امکانات سالورا</p>
          <h2 class={`${displayClass} mt-3 text-3xl leading-tight text-[#3f2730] sm:text-5xl`}>
            همه چیزهایی که سالن نیاز دارد
          </h2>
          <p class="mt-4 text-base leading-8 text-[#6b4955]">
            از ثبت نوبت تا پیگیری مشتری، همه ابزارهای روزانه سالن در یک پنل.
          </p>
        </div>

        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map((feature) => {
              const Icon = feature.icon
              return (
                <article
                  class="group rounded-2xl border border-[#f3d5dd] bg-white/80 p-6 shadow-[0_18px_50px_rgba(155,51,72,0.06)] backdrop-blur transition hover:-translate-y-1 hover:border-[#e8a8ba] hover:shadow-[0_24px_60px_rgba(155,51,72,0.12)]"
                >
                  <div class="mb-5 grid h-12 w-12 place-items-center rounded-xl bg-gradient-to-br from-[#fde2e9] to-[#f5b6c6] text-[#9b2f4a] transition group-hover:from-[#9b2f4a] group-hover:to-[#c3425b] group-hover:text-white">
                    <Icon className="h-6 w-6" aria-hidden="true" />
                  </div>
                  <h3 class="text-lg font-extrabold text-[#3f2730]">{feature.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-[#6b4955]">{feature.text}</p>
                </article>
              )
            })
          }
        </div>
      </div>
    </section>

    {/* DASHBOARD PREVIEW */}
    <section
      id="preview"
      class="relative isolate overflow-hidden px-5 py-20 sm:px-8 sm:py-24"
    >
      <img
        src="/landing/section-bg.webp"
        alt=""
        width="1920"
        height="1080"
        decoding="async"
        class="absolute inset-0 -z-10 h-full w-full object-cover"
      />
      <div
        class="absolute inset-0 -z-10 bg-gradient-to-b from-[#fdf5f8]/30 via-[#fdf5f8]/10 to-[#fdf5f8]/40"
      >
      </div>

      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-sm font-extrabold text-[#9b3348]">داشبورد سالورا</p>
          <h2 class={`${displayClass} mt-3 text-3xl leading-tight text-[#3f2730] sm:text-5xl`}>
            همه آنچه نیاز دارید در یک نگاه
          </h2>
          <p class="mt-4 text-base leading-8 text-[#6b4955]">
            برنامه روز، آمار درآمد، مشتریان و عملکرد پرسنل به‌صورت زنده.
          </p>
        </div>

        <div
          class="mt-12 overflow-hidden rounded-3xl border border-white/60 bg-white/85 p-4 shadow-[0_30px_80px_rgba(155,51,72,0.14)] backdrop-blur-md sm:p-6 lg:p-8"
        >
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {
              dashboardMetrics.map((m) => (
                <div class="rounded-xl border border-[#f3d5dd] bg-white p-4 shadow-sm">
                  <div class="flex items-center justify-between">
                    <span
                      class={`grid h-9 w-9 place-items-center rounded-lg ${toneClass[m.tone]}`}
                    >
                      <Sparkles className="h-4 w-4" aria-hidden="true" />
                    </span>
                    <span class="text-xs font-bold text-emerald-600">{m.delta}</span>
                  </div>
                  <p class="mt-4 text-xs text-[#8b6b73]">{m.label}</p>
                  <p class={`${displayClass} mt-1 text-2xl text-[#3f2730]`}>{m.value}</p>
                </div>
              ))
            }
          </div>

          <div class="mt-4 grid gap-4 lg:grid-cols-[1.3fr_1fr]">
            <div class="rounded-xl border border-[#f3d5dd] bg-white p-5">
              <div class="flex items-center justify-between border-b border-[#f3d5dd] pb-3">
                <p class="text-sm font-extrabold text-[#3f2730]">رزروهای امروز</p>
                <span class="rounded-md bg-[#fce5ec] px-2 py-0.5 text-xs font-bold text-[#9b2f4a]">
                  امروز
                </span>
              </div>
              <ul class="mt-4 space-y-3">
                {
                  upcomingAppointments.map((a) => (
                    <li class="grid grid-cols-[auto_1fr_auto] items-center gap-3 rounded-lg border border-[#f8e0e7] bg-[#fdf5f8] p-3">
                      <span class={`${displayClass} text-base text-[#9b2f4a]`} dir="ltr">
                        {a.time}
                      </span>
                      <div class="min-w-0">
                        <p class="truncate text-sm font-bold text-[#3f2730]">{a.name}</p>
                        <p class="mt-0.5 truncate text-xs text-[#8b6b73]">{a.staff}</p>
                      </div>
                      <span class="h-2 w-2 rounded-full bg-rose-400" aria-hidden="true" />
                    </li>
                  ))
                }
              </ul>
            </div>

            <div class="rounded-xl border border-[#f3d5dd] bg-white p-5">
              <div class="flex items-center justify-between border-b border-[#f3d5dd] pb-3">
                <p class="text-sm font-extrabold text-[#3f2730]">سرویس‌های پرطرفدار</p>
                <span class="text-xs text-[#8b6b73]">این هفته</span>
              </div>
              <ul class="mt-4 space-y-4">
                {
                  popularServices.map((s) => (
                    <li>
                      <div class="mb-1.5 flex items-center justify-between text-sm">
                        <span class="font-bold text-[#3f2730]">{s.name}</span>
                        <span class="font-bold text-[#9b2f4a]" dir="ltr">
                          {s.value}%
                        </span>
                      </div>
                      <div class="h-2 overflow-hidden rounded-full bg-[#fce5ec]">
                        <div
                          class="h-full rounded-full bg-gradient-to-l from-[#c3425b] to-[#e8a8ba]"
                          style={`width: ${s.value}%`}
                        />
                      </div>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          {
            stats.map((s) => (
              <div class="rounded-2xl border border-[#f3d5dd] bg-white/80 p-6 text-center backdrop-blur">
                <p class={`${displayClass} text-3xl text-[#9b2f4a]`}>{s.value}</p>
                <p class="mt-2 text-sm text-[#6b4955]">{s.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* TESTIMONIALS */}
    <section id="testimonials" class="relative px-5 py-20 sm:px-8 sm:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-sm font-extrabold text-[#9b3348]">نظرات کاربران</p>
          <h2 class={`${displayClass} mt-3 text-3xl leading-tight text-[#3f2730] sm:text-5xl`}>
            آنچه مشتریان ما می‌گویند
          </h2>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-3">
          {
            testimonials.map((t) => (
              <figure class="flex flex-col gap-5 rounded-2xl border border-[#f3d5dd] bg-white/85 p-6 shadow-[0_18px_50px_rgba(155,51,72,0.07)] backdrop-blur">
                <div class="flex gap-1 text-[#c3425b]" aria-hidden="true">
                  {'★★★★★'.split('').map((star) => (
                    <span>{star}</span>
                  ))}
                </div>
                <blockquote class="text-sm leading-7 text-[#3f2730]">«{t.quote}»</blockquote>
                <figcaption class="flex items-center gap-3 border-t border-[#f3d5dd] pt-4">
                  <span class="grid h-11 w-11 place-items-center rounded-full bg-gradient-to-br from-[#fde2e9] to-[#e8a8ba] text-base font-extrabold text-[#7a2a40]">
                    {t.name.charAt(0)}
                  </span>
                  <span class="min-w-0">
                    <p class="truncate text-sm font-extrabold text-[#3f2730]">{t.name}</p>
                    <p class="mt-0.5 truncate text-xs text-[#8b6b73]">{t.role}</p>
                  </span>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    {/* CTA */}
    <section id="start" class="relative px-5 pb-24 sm:px-8">
      <div class="relative mx-auto max-w-7xl overflow-hidden rounded-3xl">
        <img
          src="/landing/cta-bg.webp"
          alt=""
          width="1920"
          height="1080"
          decoding="async"
          class="absolute inset-0 -z-10 h-full w-full object-cover"
        />
        <div
          class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,rgba(255,255,255,0.55)_0%,rgba(255,235,242,0.45)_100%)]"
        >
        </div>

        <div class="mx-auto max-w-3xl px-6 py-16 text-center sm:px-10 sm:py-20">
          <h2 class={`${displayClass} text-3xl leading-tight text-[#4a1e2e] sm:text-5xl`}>
            آماده‌ای سالن خود را آنلاین کنی؟
          </h2>
          <p class="mt-5 text-base leading-8 text-[#6b4955] sm:text-lg">
            همین حالا حساب مدیر بساز و اولین نوبت سالن را در سالورا ثبت کن.
          </p>

          <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href={signupHref}
              class="w-full rounded-md bg-[#c3425b] px-8 py-3 text-center text-base font-bold text-white shadow-[0_18px_40px_rgba(124,28,48,0.32)] transition hover:bg-[#a82b46] sm:w-auto"
            >
              ساخت حساب رایگان
            </a>
            <a
              href={loginHref}
              class="w-full rounded-md border border-[#d68aa0] bg-white/80 px-8 py-3 text-center text-base font-bold text-[#7a2a40] backdrop-blur transition hover:bg-white sm:w-auto"
            >
              ورود به حساب
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* FOOTER */}
    <footer class="border-t border-[#f3d5dd] bg-white/60 px-5 py-8 sm:px-8">
      <div
        class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 sm:flex-row"
      >
        <div class="flex items-center gap-2.5">
          <img
            src="/landing/saloora-mark.png"
            alt=""
            width="32"
            height="32"
            decoding="async"
            class="h-8 w-8"
          />
          <span class={`${displayClass} text-xl text-[#7a2a40]`}>سالورا</span>
        </div>
        <p class="text-xs text-[#8b6b73]">© ۱۴۰۴ سالورا. تمام حقوق محفوظ است.</p>
        <div class="flex items-center gap-1.5 text-xs text-[#8b6b73]">
          <Wallet className="h-3.5 w-3.5" aria-hidden="true" />
          <span>ساخته‌شده برای سالن‌های ایرانی</span>
        </div>
      </div>
    </footer>
  </main>
</Base>
