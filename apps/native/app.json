{
  "expo": {
    "name": "Saloora",
    "slug": "saloora",
    "scheme": "saloora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8EFF0"
    },
    "assetBundlePatterns": ["**/*"],
    "experiments": {
      "tsconfigPaths": true,
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "apiBaseUrl": "https://aravira-saloon.vercel.app",
      "webBaseUrl": "https://aravira-saloon.vercel.app"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.saloora.app"
    },
    "android": {
      "package": "com.saloora.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8EFF0"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "locales": {}
  }
}
